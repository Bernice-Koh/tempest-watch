# tempest-watch environment variables — TEMPLATE
#
# Copy this file to `.env` and fill in real values for local dev.
# Never commit `.env`. The `.gitignore` already excludes it.
# Production uses the same variable names, set on the deploy box.

# --- runtime ---
# One of: development, test, production. Drives logging format and debug behaviour.
APP_ENV=development

# --- database ---
# Local dev points at the docker-compose Postgres in deploy/docker-compose.yml.
# Production points at the RDS instance. Same variable name, different value per environment.
DATABASE_URL=postgresql+psycopg://tempest:tempest@localhost:5432/tempest_watch

# --- external APIs ---
# pokemontcg.io — works without a key on lower rate limits.
# Get a free key at https://dev.pokemontcg.io/ for higher limits.
POKEMONTCG_API_KEY=

# eBay Browse API — register an app at https://developer.ebay.com/
EBAY_APP_ID=
EBAY_CERT_ID=

# --- LLM ---
# Endpoint for the matcher's contextual pass and judge stages.
# Direct provider key, no managed proxy.
LLM_API_KEY=
LLM_MODEL=

# --- alerting ---
# Telegram bot — created via @BotFather. CHAT_ID is yours, obtained from the bot
# after sending it any message and calling getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
